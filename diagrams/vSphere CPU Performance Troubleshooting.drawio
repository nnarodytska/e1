        <mxCell id="1sun8TP_CNhC76_nkfZT-46" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;glass=1;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;vSphere Cluster Troubleshooting&amp;nbsp;&lt;/h1&gt;&lt;p&gt;Workflow to determine the root cause of a Cluster performance. A cluster does not perform if it can&#39;t serve the demand. It starts with VM(s) being affected, unable to get the resource they are demanding.&lt;/p&gt;" vertex="1">
          <mxGeometry height="120" width="660" x="110" y="60" as="geometry" />
        </mxCell>
        <mxCell id="1sun8TP_CNhC76_nkfZT-48" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="Slowness in VM population is actually a range. Wide problem means a large percentage, while narrow means a small percentage. They have different root cause, hence different worflow." vertex="1">
          <mxGeometry height="30" width="590" x="154" y="1030" as="geometry" />
        </mxCell>
        <mxCell id="1sun8TP_CNhC76_nkfZT-50" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="" vertex="1">

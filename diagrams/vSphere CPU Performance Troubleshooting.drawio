        </mxCell>
        <mxCell id="1sun8TP_CNhC76_nkfZT-54" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="Green boxes is typically caused by consumer. This means VM, or how you slice the clusters (Resource Pools, VM - Host Affinity)." vertex="1">
          <mxGeometry height="30" width="590" x="154" y="1070" as="geometry" />
        </mxCell>
